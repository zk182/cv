---
import BaseLayout from "../layouts/BaseLayout.astro";
import Link from "../components/Link.astro";

import { Image } from "astro:assets";
import profilePhoto from "../images/me.webp";
---

<style>
	section {
		border-block-end: var(--accent) solid 2px;
		padding: 3rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	section:last-of-type {
		border-block-end: none;
	}

	.sub-title {
		font-size: 1.5rem;
		font-weight: 500;
	}

	/* Intro */

	.intro-container {
		justify-content: center;
	}

	.profile-image {
		margin: auto;
		border-radius: 50%;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
		transition: box-shadow 0.3s ease;
		object-fit: cover;
		object-position: center 20%;
		display: block;
		width: 14rem;
		height: 14rem;
	}

	.profile-image:hover {
		box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
	}

	.highlights-container {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.highlights-list {
		list-style-type: none;
	}

	.highlights-list-item {
		position: relative;
		margin-block-end: 1.5rem;
		padding-left: 1rem;
	}

	.highlights-list-item:last-child {
		margin-block-end: 0;
	}

	.highlights-container ul li::before {
		content: "•";
		font-size: 1.2rem;
		position: absolute;
		left: 0;
		top: -2px;
	}

	/* Experience */
	.experience-list {
		position: relative;
		padding: 0;
		margin-inline-start: 0.5rem;
		border-inline-start: var(--accent) 2px solid;
		list-style-type: none;
	}

	.experience-list-item {
		padding-inline-start: 1rem;
		margin-block-end: 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		position: relative;
	}

	.experience-list-item:last-child {
		margin-block-end: 0;
	}

	.experience-list-item::before {
		content: "";
		position: absolute;
		left: -0.6rem;
		top: 0rem;
		height: 1rem;
		width: 1rem;
		border-radius: 50%;
		border: 1px solid var(--accent);
		background-color: var(--accent);
	}

	.experience-list-item-title {
		grid-row: 2;
		color: var(--text-primary);
		margin: 0;
		font-size: 1.2rem;
	}

	.experience-list-item-date {
		grid-row: 1;
		color: var(--text-secondary);
		font-size: 1rem;
		margin: 0;
	}

	.experience-list-item-description {
		grid-row: 3;
		font-size: 1rem;
		line-height: 1.5;
		list-style-type: disc;
		list-style-position: outside;
		padding: 0;
	}

	.experience-list-item-description-item {
		margin-inline-start: 1rem;
		margin-block-end: 0.5rem;
		position: relative;
	}

	.experience-list-item-description-item:last-child {
		margin-block-end: 0;
	}

	/* Responsive */
	@media (min-width: 640px) {
		.intro-container {
			display: flex;
			flex-direction: row;
			gap: 3rem;
		}
	}
</style>

<BaseLayout>
	<section id="intro" class="intro-container">
		<Image
			src={profilePhoto}
			alt="Nicolás Battaglia"
			class="profile-image"
			loading="eager"
		/>

		<div class="highlights-container">
			<h2 class="sub-title">About</h2>
			<ul class="highlights-list">
				<li class="highlights-list-item">
					Sr. Backend Engineer at <Link href="https://modo.com.ar">MODO</Link>
				</li>
				<li class="highlights-list-item">
					Engineer with strong background in Node.js & distributed systems
				</li>
				<li class="highlights-list-item">
					Exploring <Link href="https://go.dev">Go</Link> & <Link
						href="https://www.rust-lang.org">Rust</Link
					>
				</li>
				<li class="highlights-list-item">
					Based in Mar del Plata, Argentina
				</li>
				<li class="highlights-list-item">
					<Link href="https://linkedin.com/in/nicobattaglia">LinkedIn</Link>
				</li>
			</ul>
		</div>
	</section>

	<section id="experience">
		<h2 class="sub-title">Experience</h2>
		<ol class="experience-list">
			<li class="experience-list-item">
				<h3 class="experience-list-item-title">MODO — Sr. Backend Engineer</h3>
				<p class="experience-list-item-date">February 2025 – Present</p>
				<ol class="experience-list-item-description">
					<li class="experience-list-item-description-item">
						Core backend engineer for a QR-based payment system used by ~150K
						daily users, enabling seamless ride payments directly from bank
						accounts
					</li>
					<li class="experience-list-item-description-item">
						Designed and shipped the end-to-end trip & payment flow: QR scan →
						async processing via SQS → bank debit confirmation
					</li>
					<li class="experience-list-item-description-item">
						Built fraud prevention systems (deny lists, account blocking) and
						automated debt recovery
					</li>
					<li class="experience-list-item-description-item">
						Shipped offline QR support with certificate signing for unreliable
						connectivity scenarios
					</li>
					<li class="experience-list-item-description-item">
						Led production on-call, handling incidents with Datadog; operated
						services via AWS Lambdas + Kubernetes
					</li>
				</ol>
			</li>

			<li class="experience-list-item">
				<h3 class="experience-list-item-title">
					Denode — Backend Developer
				</h3>
				<p class="experience-list-item-date">October 2023 – February 2025</p>
				<ol class="experience-list-item-description">
					<li class="experience-list-item-description-item">
						Developed <Link href="https://www.remove.bg/">Remove Background</Link>, an app for isolating subjects
						from images
					</li>
					<li class="experience-list-item-description-item">
						Full stack (Node.js + React) for <em>Feels Like Gaming</em>: a
						platform to store and manage commercial gaming keys across Xbox,
						PlayStation, and more
					</li>
					<li class="experience-list-item-description-item">
						Built real-time stock visibility, transaction history, and stock
						management for administrators
					</li>
				</ol>
			</li>

			<li class="experience-list-item">
				<h3 class="experience-list-item-title">
					SecurityScorecard — Sr. Backend Engineer
				</h3>
				<p class="experience-list-item-date">October 2021 – March 2023</p>
				<ol class="experience-list-item-description">
					<li class="experience-list-item-description-item">
						Developed a rate limit solution extended across the organization to
						track endpoint and function usage, enabling access segmentation by
						user type
					</li>
					<li class="experience-list-item-description-item">
						Worked on <Link href="https://securityscorecard.com/blog/what-is-cyber-risk-quantification/">Cyber Risk Quantification (CRQ)</Link>: translating cyber risk
						into financial terms to support cost-benefit analysis of security
						investments
					</li>
				</ol>
			</li>

			<li class="experience-list-item">
				<h3 class="experience-list-item-title">MURAL — Developer</h3>
				<p class="experience-list-item-date">October 2020 – October 2021</p>
				<ol class="experience-list-item-description">
					<li class="experience-list-item-description-item">
						Canvas Workflows team: export/import, visualization of external
						content, image search & cropping
					</li>
					<li class="experience-list-item-description-item">
						Core Platform team: extensibility, integrations, and third-party API
						development
					</li>
				</ol>
			</li>

			<li class="experience-list-item">
				<h3 class="experience-list-item-title">
					SparkDigital — Sr. Software Engineer
				</h3>
				<p class="experience-list-item-date">August 2018 – October 2020</p>
				<ol class="experience-list-item-description">
					<li class="experience-list-item-description-item">
						Backend design from scratch with Node.js for <Link href="https://wwnorton.com/">W. W. Norton</Link>, focusing on scalability and
						performance (NestJS, Fastify, GraphQL, MongoDB, Redis)
					</li>
					<li class="experience-list-item-description-item">
						Real-time collaboration backend for a Gantt project tool using
						Socket.io, Firebase, and JWT
					</li>
					<li class="experience-list-item-description-item">
						Co-founded the RAY Initiative: internal project incubator for
						employee professional development
					</li>
				</ol>
			</li>

		</ol>
	</section>

	<section id="education">
		<h2 class="sub-title">Education</h2>
		<ol class="experience-list">
			<li class="experience-list-item">
				<h3 class="experience-list-item-title">
					Universidad FASTA — Computer Engineering
				</h3>
				<p class="experience-list-item-date">2008 – 2017</p>
				<ol class="experience-list-item-description">
					<li class="experience-list-item-description-item">
						Research in Computer Forensics under the FOMO project (Mobile
						Forensics): analysis of Android OS physical and logical data
						extraction
					</li>
				</ol>
			</li>
		</ol>
	</section>
</BaseLayout>
